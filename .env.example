# Atlas Alpha — 환경변수 예시. 실제 키는 .env 에 넣으세요(.env 는 git 무시됨).
# 복사:  cp .env.example .env   그리고 값 채우기.  실행:  npm run alpha (자동으로 .env 로드)

# ── 서버 ──
PORT=4317
HOST=0.0.0.0          # 0.0.0.0 = 같은 WiFi 핸드폰에서 접속 가능 (127.0.0.1 = 이 컴퓨터만)
ATLAS_PASS=atlas      # 로그인 비밀번호
# ATLAS_DATA=/path/to/alpha.json   # (선택) 데이터 파일 경로

# ── 텍스트 생성 (실제 AI ON/OFF 토글) ──
# 기본은 OFF(mock). 실제 생성을 켜려면 (1)ATLAS_LLM=on (2)ANTHROPIC_API_KEY 둘 다 설정.
# 키는 절대 코드에 넣지 마세요(.env 에만, git 무시됨).
#
#   실제 생성 켜는 법:
#     1) cp .env.example .env
#     2) .env 에서  ATLAS_LLM=on  으로 바꾸고  ANTHROPIC_API_KEY=sk-ant-... 채우기
#     3) npm run alpha   (시작 로그에 "텍스트 생성: 실제 AI ON" 표시되면 적용됨)
#   실제 생성 대상은 social_post/ad_copy/report/customer_reply/checklist/image_brief 만.
#   이미지/영상은 절대 실제 생성하지 않음. 키 없거나 호출 실패 시 자동으로 mock 폴백.
ATLAS_LLM=off                       # on = 실제 Claude 호출 / off(또는 미설정) = mock
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx # 실제 키 (실제 생성 시에만 필요)
# ATLAS_LLM_MODEL=claude-haiku-4-5  # (선택) 기본 Cost First 모델
# ATLAS_LLM_URL=https://api.anthropic.com/v1/messages  # (선택·고급) 호환 프록시/검증용 엔드포인트 override
